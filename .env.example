# ========================================
# PDF 翻译工程配置文件
# ========================================
# 使用说明：
# 1. 将此文件复制为 .env
# 2. 根据实际需求修改配置项
# 3. 敏感信息（如 API 密钥）不要提交到版本控制
# ========================================

# ----------------------------------------
# API 密钥配置
# ----------------------------------------

# 阿里云 DashScope API 密钥
# 获取地址：https://dashscope.console.aliyun.com/apiKey
ALIYUN_KEY=sk-your-api-key-here

# 阿里云 DashScope 基础 URL（通常不需要修改）
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ----------------------------------------
# 翻译模型配置
# ----------------------------------------

# 使用的翻译模型名称
# 可选值：qwen-plus, qwen-max, qwen-turbo 等
# qwen-plus: 性能均衡，推荐日常使用
# qwen-max: 效果最好，但成本较高
# qwen-turbo: 速度最快，成本最低
TRANSLATE_MODEL=qwen-plus

# 翻译提示词模板
# {text} 会被待翻译的文本块替换
# 可根据专业领域调整提示词，如"法律"、"医学"、"计算机"等
TRANSLATE_PROMPT=你是一个化学与环境专业的翻译助手。请将以下内容准确、流畅地翻译成中文，原文中有较多的化学公式和环境相关的专业术语。请保持原意，不要添加解释、不要输出原文，只输出译文。

# ----------------------------------------
# 翻译参数配置
# ----------------------------------------

# 模型温度（0.0-2.0）
# 较低值（0.1-0.3）：输出更确定、保守
# 较高值（0.7-1.0）：输出更creative、多样
# 翻译任务建议使用较低值以保证准确性
TRANSLATE_TEMPERATURE=0.3

# 最大生成 token 数
# 根据分块大小调整，一般设置为分块大小的 1/2 到 2/3
# 注意：中文字符约 1.5 个/token
TRANSLATE_MAX_TOKENS=2000

# ----------------------------------------
# 文本分块配置
# ----------------------------------------

# 最大分块大小（字符数）
# 用于将长文本分割成多个块进行翻译，避免超出 API 限制
# 建议值：2000-4000，根据文档复杂度调整
MAX_CHUNK_SIZE=3000

# ----------------------------------------
# 速率限制配置
# ----------------------------------------

# 翻译块之间的延迟时间（秒）
# 用于避免触发 API 速率限制
# 如果频繁遇到限流，可适当增加此值
CHUNK_DELAY=2

# 翻译文件之间的延迟时间（秒）
# 每个文件翻译完成后暂停的时间
FILE_DELAY=5

# ----------------------------------------
# 日志配置
# ----------------------------------------

# 日志级别
# 可选值：DEBUG, INFO, WARNING, ERROR, CRITICAL
# DEBUG: 输出详细调试信息
# INFO: 输出一般运行信息（推荐）
# WARNING: 仅输出警告信息
LOG_LEVEL=INFO

# 日志目录
# 相对于项目根目录的路径
LOG_DIR=logs

# 单个日志文件最大大小（字节）
# 默认 10MB，达到上限后自动轮转
LOG_MAX_BYTES=10485760

# 保留的备份日志文件数量
# 旧日志会自动命名为 xxx.log.1, xxx.log.2 等
LOG_BACKUP_COUNT=3
